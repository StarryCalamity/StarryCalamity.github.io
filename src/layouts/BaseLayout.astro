---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description } = Astro.props;
const pageTitle = description ? `${title} — ${description}` : title;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? ""} />

    <title>{pageTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <div class="site-title">
          <a href="/">技术杂记</a>
        </div>
        <div class="site-subtitle">代码与创造的点滴记录</div>
        <nav class="site-nav">
          <a href="/" class={Astro.url.pathname === "/" ? "active" : ""}>文章</a>
          <a href="/projects" class={Astro.url.pathname.startsWith("/projects") ? "active" : ""}>项目</a>
          <a href="/about" class={Astro.url.pathname === "/about" ? "active" : ""}>关于</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <span>一步一个脚印</span>
      </div>
    </footer>
  </body>
</html>
